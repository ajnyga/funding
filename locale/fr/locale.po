msgid "plugins.generic.funding.displayName"
msgstr "Données de Fonds"

msgid "plugins.generic.funding.description"
msgstr "Ce plugin ajoute les données de financement des soumissions en utilisant le registre des financeurs de Crossref, et intègre les données dans l'exportation XML de Crossref."

msgid "plugins.generic.funding.settings.description"
msgstr "Les paramètres suivants contrôlent la collecte et l'utilisation des informations relatives au financement saisies lors de chaque soumission."

msgid "plugins.generic.funding.settings.enableGrantIdValidation"
msgstr "Activer la validation de l'identifiant de subvention pour les bailleurs de fonds pris en charge (à l'aide de l'API Zenodo)."

msgid "plugins.generic.funding.fundIdInvalid"
msgstr "Un ou plusieurs identifiants de subvention ne sont pas valides pour le bailleur de fonds spécifié. Veuillez vérifier à nouveau les identifiants de fonds."

msgid "plugins.generic.funding.fundingData"
msgstr "Données de Fonds"

msgid "plugins.generic.funding.publication.fundingData"
msgstr "Publication: Données de Fonds"

msgid "plugins.generic.funding.addFunder"
msgstr "Ajouter un financeur"

msgid "plugins.generic.funding.funderName"
msgstr "Nom du bailleur de fonds"

msgid "plugins.generic.funding.funderSubOrganization"
msgstr "Sous-organisation"

msgid "plugins.generic.funding.funderSubOrganization.select"
msgstr "Choisir une sous-organisation"

msgid "plugins.generic.funding.funderIdentification"
msgstr "ID du bailleur de fonds"

msgid "plugins.generic.funding.funderNameIdentification"
msgstr "Nom et identification du bailleur de fonds"

msgid "plugins.generic.funding.funderGrants"
msgstr "Numéros de subventions"

msgid "plugins.generic.funding.noneCreated"
msgstr "Aucun bailleur de fonds"

msgid "plugins.generic.funding.funderNameIdentificationRequired"
msgstr "Nom du bailleur de fonds requis"

msgid "plugins.generic.funding.funderNameIdentificationRequired.registry"
msgstr "Seuls les financeurs du registre Crossref sont autorisés."

msgid "plugins.generic.funding.submissionWizard.name"
msgstr "Financeurs"

msgid "plugins.generic.funding.submissionWizard.description"
msgstr "Veuillez fournir des informations sur les institutions qui ont financé la recherche à l'origine de ce travail. Seuls les financeurs figurant dans le registre Crossref sont pris en charge. Si vous avez reçu des fonds d'une institution et que vous ne pouvez pas les trouver pour les ajouter ici, veuillez fournir ces informations dans le champ Commentaires pour l'éditeur."
